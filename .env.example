# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=angelman

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@postgres:5432/angelman?sslmode=disable
DIRECT_DATABASE_URL=postgres://postgres:postgres@localhost:5432/angelman?sslmode=disable
ALLOWED_ORIGIN=https://localhost:3000
PORT=8080

BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000
ADMIN_SECRET=<generate with: openssl rand -base64 32>

# ── Frontend ────────────────────────────────────────────────────────────────
